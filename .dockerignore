# Backend (não necessário para o build do frontend)
backend/

# Dependências locais — reinstaladas no build
frontend/node_modules/
.npm/

# Artefatos de build locais
frontend/dist/

# Arquivos de controle de versão
.git/
.gitignore

# Documentação e configs de desenvolvimento
*.md
.editorconfig
.eslintrc*
.prettierrc*

# Variáveis de ambiente locais (nunca enviar ao container)
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Configs de IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Docker (evita loop)
docker-compose*

# Logs e temporários
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
tmp/
temp/
coverage/
.nyc_output/
