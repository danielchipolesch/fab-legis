# ─────────────────────────────────────────────────────────────
# FAB Legis Frontend — variáveis de ambiente
# Copie para .env.local e ajuste para o seu ambiente.
# Variáveis VITE_* são embutidas no build (não são secrets).
# ─────────────────────────────────────────────────────────────

# Modo mock: 'true' usa localStorage (sem backend). 'false' ativa chamadas reais.
# Mantenha 'true' até o backend estar disponível.
VITE_USE_MOCK_API=true

# URL base da API REST do backend (ignorada enquanto VITE_USE_MOCK_API=true)
VITE_API_BASE_URL=http://localhost:8080/api

# Ambiente (development | staging | production)
VITE_APP_ENV=development

# Versão da aplicação (usada em logs/sentry)
VITE_APP_VERSION=1.0.0
